class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        left = 0
        seen  =set()
        total = 0

        for i in range(len(s)):
            char = s[i] 

            while char in seen:
                seen.remove(s[left])
                left+=1

            seen.add(char)

            total = max(total, i-left+1)
        return total

s="abcabcbb"
obj = Solution()

print(obj.lengthOfLongestSubstring(s))
